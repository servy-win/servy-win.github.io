{
  "name": "servy-win.github.io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && node scripts/inject-preload.js",
    "preview": "vite preview",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix",
    "validate:html": "html-validate .",
    "lhci": "npm run build && lhci autorun",
    "prepare": "husky",
    "ncu": "npm-check-updates -u",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "npm test -- --coverage --no-cache",
    "size": "ls -lh dist/assets",
    "budget-check": "lhci autorun"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "eslint": "^10.2.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "html-validate": "^10.11.3",
    "husky": "^9.1.7",
    "inquirer": "^13.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "npm-check-updates": "^20.0.0",
    "vite": "^8.0.7",
    "vite-plugin-html": "^3.2.2"
  },
  "dependencies": {
    "lite-youtube-embed": "^0.3.4"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/__tests__/__mocks__/styleMock.js",
      "lite-youtube-embed.*": "<rootDir>/__tests__/__mocks__/styleMock.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__mocks__/"
    ],
    "collectCoverageFrom": [
      "src/js/**/*.js",
      "!src/js/ga.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "cobertura",
      "html"
    ]
  },
  "overrides": {
    "tmp": "^0.2.3"
  }
}
